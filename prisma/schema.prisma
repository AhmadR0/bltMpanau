// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "./generated"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  username  String   @unique
  password  String
  role      Role     @default(USER)
  warga     Warga?
}

model Warga {
  id         Int      @id @default(autoincrement())
  nik        String   @unique
  nama       String
  status     Status   @default(Menunggu)
  fotoKtp    String?
  fotoKk     String?
  fotoRumah  String?
  fotoDapur  String?
  address    String?
  noHp       String?
  isDeleted  Boolean        @default(false)
  user       User           @relation(fields: [userId], references: [id])
  userId     Int            @unique
  notes      RejectedNote[] // Relasi One-to-Many ke catatan penolakan
}

model RejectedNote {
  id        Int      @id @default(autoincrement())
  wargaId   Int
  warga     Warga    @relation(fields: [wargaId], references: [id], onDelete: Cascade)
  catatan   String   @db.Text
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

enum Status {
  Menunggu
  Disetujui
  Ditolak
}